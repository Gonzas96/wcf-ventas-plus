<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<connectionStrings>
		<add name="VentaPlusDB"
			 connectionString="Data Source=localhost;Initial Catalog=VentaPlusDB;User ID=sa;Password=sa;TrustServerCertificate=True"
			 providerName="System.Data.SqlClient" />
	</connectionStrings>

	<system.serviceModel>

		<services>
			<service name="WCF_VentasPlusSeguroWS.VentasWS"
					 behaviorConfiguration="comportamientoSeguro">
				<endpoint address=""
						  binding="basicHttpBinding"
						  bindingConfiguration="bindingSeguro"
						  contract="WCF_VentasPlusSeguroWS.IVentasService" />
				<endpoint address="mex"
						  binding="mexHttpBinding"
						  contract="IMetadataExchange" />
				<host>
					<baseAddresses>
						<add baseAddress="http://localhost:8733/VentasSeguro" />
					</baseAddresses>
				</host>
			</service>
		</services>

		<bindings>
			<basicHttpBinding>
				<binding name="bindingSeguro">
					<security mode="TransportCredentialOnly">
						<transport clientCredentialType="Basic" />
					</security>
				</binding>
			</basicHttpBinding>
		</bindings>

		<behaviors>
			<serviceBehaviors>
				<behavior name="comportamientoSeguro">
					<serviceMetadata httpGetEnabled="true" />
					<serviceDebug includeExceptionDetailInFaults="true" />
					<serviceCredentials>
						<userNameAuthentication
						  userNamePasswordValidationMode="Custom"
						  customUserNamePasswordValidatorType="WCF_VentasPlusSeguroWS.Autenticar, WCF_VentasPlusSeguroWS" />
					</serviceCredentials>
				</behavior>
			</serviceBehaviors>
		</behaviors>

	</system.serviceModel>

</configuration>